# Public (browser) Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only Supabase (DO NOT expose to browser)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Supabase JWT secret (Project Settings → API → JWT Secret)
# Required for server-side RLS enforcement using NextAuth sessions.
SUPABASE_JWT_SECRET="YOUR_SUPABASE_JWT_SECRET"

# NextAuth
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
GITHUB_ID="YOUR_GITHUB_OAUTH_CLIENT_ID"
GITHUB_SECRET="YOUR_GITHUB_OAUTH_CLIENT_SECRET"

GOOGLE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"

# Invite token hashing salt (optional; falls back to NEXTAUTH_SECRET)
INVITE_TOKEN_SALT="optional-extra-salt"
